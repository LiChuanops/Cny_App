{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "简易出入库管理系统 (Cloudflare Pages + D1)",
  "private": true,
  "scripts": {
    "db:local": "wrangler d1 execute inventory-db --local --file=schema.sql",
    "db:remote": "wrangler d1 execute inventory-db --remote --file=schema.sql",
    "dev": "wrangler pages dev",
    "deploy": "wrangler pages deploy"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
